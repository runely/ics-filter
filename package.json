{
  "name": "ics-filter",
  "version": "1.0.0",
  "description": "A simple module that filters raw iCalendar content",
  "main": "./dist/index.js",
  "type": "module",
  "files": [
    "dist/index.*"
  ],
  "scripts": {
    "build": "npm run lint && tsc",
    "lint": "biome check",
    "lint:fix": "biome check --write",
